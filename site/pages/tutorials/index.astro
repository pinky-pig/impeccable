---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import '../../styles/sub-pages.css';

const tutorials = (await getCollection('tutorials'))
  .sort((a, b) => a.data.order - b.data.order);
---

<Base
  title="教程 | Impeccable"
  description="从第一次安装到浏览器里的实时迭代，4 篇按步骤展开的教程，带你走通 Impeccable 最值得先掌握的工作流。"
  activeNav="docs"
  canonicalPath="/tutorials"
  bodyClass="sub-page"
>
  <div class="tutorials-index">
    <header class="tutorials-index-header">
      <h1 class="sub-page-title">教程</h1>
      <p class="sub-page-lede">4 篇按步骤展开的教程，从第一次安装到浏览器里的实时迭代，带你走通 Impeccable 最值得先掌握的工作流。</p>
    </header>

    <div class="tutorials-list">
      {tutorials.map((entry, index) => (
        <a href={`/tutorials/${entry.id}`} class="tutorial-card">
          <span class="tutorial-card-num">{String(index + 1).padStart(2, '0')}</span>
          <div>
            <h2 class="tutorial-card-title">{entry.data.title}</h2>
            <p class="tutorial-card-desc">{entry.data.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>

  <style>
    .tutorials-index {
      max-width: 860px;
      padding: 2rem 0 4rem;
    }

    .tutorials-index-header {
      margin-bottom: 2rem;
    }

    .tutorials-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .tutorials-list .tutorial-card {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 1.25rem;
      align-items: flex-start;
      padding: 1.5rem;
      border: 1px solid var(--color-mist);
      border-radius: 12px;
      transition: border-color var(--duration-fast) var(--ease-out),
        transform var(--duration-fast) var(--ease-out),
        box-shadow var(--duration-fast) var(--ease-out);
    }

    .tutorials-list .tutorial-card:hover {
      border-color: var(--color-ink);
      transform: translateY(-1px);
      box-shadow: 0 10px 28px -18px rgba(0, 0, 0, 0.28);
    }

    .tutorial-card-num {
      display: inline-block;
      min-width: 2ch;
      font-family: var(--font-mono);
      font-size: 1rem;
      font-weight: 600;
      color: var(--color-ash);
      line-height: 1.2;
      padding-top: 0.125rem;
    }

    .tutorials-list .tutorial-card:hover .tutorial-card-num {
      color: var(--color-accent);
    }

    .tutorial-card-title {
      margin: 0 0 0.5rem;
    }

    .tutorial-card-desc {
      margin: 0;
      font-size: 0.9375rem;
      line-height: 1.65;
      color: var(--color-charcoal);
      max-width: 68ch;
    }

    @media (max-width: 720px) {
      .tutorials-index {
        padding: 1.5rem 0 3rem;
      }

      .tutorials-list .tutorial-card {
        grid-template-columns: 1fr;
        gap: 0.75rem;
      }
    }
  </style>
</Base>
